{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "newProjectRoot": "projects",
    "projects": {
        "sample1": {
            "projectType": "application",
            "schematics": {
                "@schematics/angular:component": {
                    "style": "scss"
                }
            },
            "root": "projects/sample1",
            "sourceRoot": "projects/sample1/src",
            "prefix": "app",
            "architect": {
                "build": {
                    "builder": "@angular-devkit/build-angular:browser",
                    "options": {
                        "outputPath": "dist/sample1",
                        "index": "projects/sample1/src/index.html",
                        "main": "projects/sample1/src/main.ts",
                        "polyfills": "projects/sample1/src/polyfills.ts",
                        "tsConfig": "projects/sample1/tsconfig.app.json",
                        "inlineStyleLanguage": "scss",
                        "assets": [
                            "projects/sample1/src/favicon.ico",
                            "projects/sample1/src/assets",
                            {
                                "glob": "**/*",
                                "input": "dist/one-system/one-sys-portal-azure/assets",
                                "output": "./assets/one-system/one-sys-portal-azure/"
                            }
                        ],
                        "styles": [
                            "projects/sample1/src/styles.scss"
                        ],
                        "scripts": []
                    },
                    "configurations": {
                        "production": {
                            "budgets": [
                                {
                                    "type": "initial",
                                    "maximumWarning": "500kb",
                                    "maximumError": "1mb"
                                },
                                {
                                    "type": "anyComponentStyle",
                                    "maximumWarning": "2kb",
                                    "maximumError": "4kb"
                                }
                            ],
                            "fileReplacements": [
                                {
                                    "replace": "projects/sample1/src/environments/environment.ts",
                                    "with": "projects/sample1/src/environments/environment.prod.ts"
                                }
                            ],
                            "outputHashing": "all"
                        },
                        "development": {
                            "buildOptimizer": false,
                            "optimization": false,
                            "vendorChunk": true,
                            "extractLicenses": false,
                            "sourceMap": true,
                            "namedChunks": true
                        }
                    },
                    "defaultConfiguration": "production"
                },
                "serve": {
                    "builder": "@angular-devkit/build-angular:dev-server",
                    "configurations": {
                        "production": {
                            "browserTarget": "sample1:build:production"
                        },
                        "development": {
                            "browserTarget": "sample1:build:development"
                        }
                    },
                    "defaultConfiguration": "development"
                },
                "extract-i18n": {
                    "builder": "@angular-devkit/build-angular:extract-i18n",
                    "options": {
                        "browserTarget": "sample1:build"
                    }
                },
                "test": {
                    "builder": "@angular-devkit/build-angular:karma",
                    "options": {
                        "main": "projects/sample1/src/test.ts",
                        "polyfills": "projects/sample1/src/polyfills.ts",
                        "tsConfig": "projects/sample1/tsconfig.spec.json",
                        "karmaConfig": "projects/sample1/karma.conf.js",
                        "inlineStyleLanguage": "scss",
                        "assets": [
                            "projects/sample1/src/favicon.ico",
                            "projects/sample1/src/assets"
                        ],
                        "styles": [
                            "projects/sample1/src/styles.scss"
                        ],
                        "scripts": []
                    }
                }
            }
        },
        "@one-system/one-sys-core": {
            "projectType": "library",
            "root": "projects/one-system/one-sys-core",
            "sourceRoot": "projects/one-system/one-sys-core/src",
            "prefix": "lib",
            "architect": {
                "build": {
                    "builder": "@angular-devkit/build-angular:ng-packagr",
                    "options": {
                        "project": "projects/one-system/one-sys-core/ng-package.json"
                    },
                    "configurations": {
                        "production": {
                            "tsConfig": "projects/one-system/one-sys-core/tsconfig.lib.prod.json"
                        },
                        "development": {
                            "tsConfig": "projects/one-system/one-sys-core/tsconfig.lib.json"
                        }
                    },
                    "defaultConfiguration": "production"
                },
                "test": {
                    "builder": "@angular-devkit/build-angular:karma",
                    "options": {
                        "main": "projects/one-system/one-sys-core/src/test.ts",
                        "tsConfig": "projects/one-system/one-sys-core/tsconfig.spec.json",
                        "karmaConfig": "projects/one-system/one-sys-core/karma.conf.js"
                    }
                }
            }
        },
        "@one-system/one-sys-portal-azure": {
            "projectType": "library",
            "root": "projects/one-system/one-sys-portal-azure",
            "sourceRoot": "projects/one-system/one-sys-portal-azure/src",
            "prefix": "lib",
            "architect": {
                "build": {
                    "builder": "@angular-devkit/build-angular:ng-packagr",
                    "options": {
                        "project": "projects/one-system/one-sys-portal-azure/ng-package.json"
                    },
                    "configurations": {
                        "production": {
                            "tsConfig": "projects/one-system/one-sys-portal-azure/tsconfig.lib.prod.json"
                        },
                        "development": {
                            "tsConfig": "projects/one-system/one-sys-portal-azure/tsconfig.lib.json"
                        }
                    },
                    "defaultConfiguration": "production"
                },
                "test": {
                    "builder": "@angular-devkit/build-angular:karma",
                    "options": {
                        "main": "projects/one-system/one-sys-portal-azure/src/test.ts",
                        "tsConfig": "projects/one-system/one-sys-portal-azure/tsconfig.spec.json",
                        "karmaConfig": "projects/one-system/one-sys-portal-azure/karma.conf.js"
                    }
                }
            }
        }
    },
    "cli": {
        "analytics": "76e576d3-32ec-4200-98a6-447a9d62a637"
    }
}
